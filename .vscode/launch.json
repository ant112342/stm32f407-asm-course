{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug current STM32 project",
      "type": "cortex-debug",
      "request": "launch",

      "servertype": "openocd",
      "serverpath": "/opt/openocd/bin/openocd",

      "gdbPath": "gdb-multiarch",
      "objdumpPath": "arm-none-eabi-objdump",
      "nmPath": "arm-none-eabi-nm",

      "executable": "${workspaceFolder}/build/current.elf",

      "configFiles": [
        "interface/stlink.cfg",
        "target/stm32f4x.cfg"
      ],

      "searchDir": [
        "${workspaceFolder}"
      ],

      "preLaunchTask": "build",
      "runToEntryPoint": "main",

      "device": "STM32F407VG",
      "svdFile": "${workspaceFolder}/.vscode/STM32F407.svd",

      "showDevDebugOutput": "raw"
    }
  ]
}